{
  "manifest_version": 3,
  "name": "Modern Tabs Outliner",
  "version": "1.0.0",
  "description": "A modern tabs outliner for Chrome and Edge.",
  "icons": {
    "16": "favicon.svg",
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "permissions": [
    "tabs",
    "windows",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Tabs Outliner",
    "default_icon": {
      "16": "favicon.svg",
      "48": "favicon.svg",
      "128": "favicon.svg"
    }
  }
}
